---
import Layout from '../layouts/Layout.astro';
import siteData from '../content/site.json';

const { hero, about, services, testimonials, career, recognition, connect } = siteData;

function renderMarkdown(text: string): string {
  return text
    .replace(/\*\*(.+?)\*\*/g, '<strong class="text-gray-100">$1</strong>')
    .replace(/\*(.+?)\*/g, '<em>$1</em>');
}
---

<Layout title="Brian Borg — Builder, Founder, Quality Obsessive">
  <!-- Hero -->
  <header class="min-h-[70vh] flex items-center">
    <div class="max-w-3xl mx-auto px-6 py-24">
      <div class="flex flex-col md:flex-row md:items-center gap-8 mb-10">
        <img
          src="/brian-borg.jpg"
          alt="Brian Borg"
          class="w-36 h-36 rounded-full object-cover object-[center_30%] border-2 border-teal-400/30 shrink-0"
        />
        <div>
          <p class="text-teal-400 font-medium mb-2 tracking-wide uppercase text-sm">Hey, I'm</p>
          <h1 class="text-5xl md:text-6xl font-bold leading-tight">Brian Borg</h1>
        </div>
      </div>
      <p class="text-xl md:text-2xl text-gray-300 mb-8 leading-relaxed" set:html={renderMarkdown(hero.tagline)} />
      <p class="text-lg text-gray-400">
        <Fragment set:html={renderMarkdown(hero.subtitle)} />
      </p>
    </div>
  </header>

  <!-- About -->
  <section id="about" class="py-20 border-t border-gray-800">
    <div class="max-w-3xl mx-auto px-6">
      <h2 class="text-3xl font-bold mb-8">{about.heading}</h2>
      <div class="space-y-5 text-lg text-gray-300 leading-relaxed">
        {about.paragraphs.map((p: string) => (
          <p set:html={renderMarkdown(p)} />
        ))}
      </div>
    </div>
  </section>

  <!-- What I Do -->
  <section id="work" class="py-20 border-t border-gray-800">
    <div class="max-w-3xl mx-auto px-6">
      <h2 class="text-3xl font-bold mb-8">What I do</h2>
      <div class="space-y-10">
        {services.map((svc: { title: string; description: string }) => (
          <div>
            <h3 class="text-xl font-semibold text-teal-400 mb-3">{svc.title}</h3>
            <p class="text-lg text-gray-300 leading-relaxed">{svc.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Testimonials -->
  <section id="testimonials" class="py-20 border-t border-gray-800">
    <div class="max-w-3xl mx-auto px-6">
      <h2 class="text-3xl font-bold mb-10">What clients say</h2>
      <div class="space-y-10">
        {testimonials.map((t: { quote: string; author: string; role: string }) => (
          <blockquote class="border-l-2 border-teal-400/50 pl-6">
            <p class="text-lg text-gray-300 italic leading-relaxed mb-3">
              "{t.quote}"
            </p>
            <cite class="text-gray-500 not-italic">— {t.author}, {t.role}</cite>
          </blockquote>
        ))}
      </div>
    </div>
  </section>

  <!-- Career Timeline -->
  <section id="journey" class="py-20 border-t border-gray-800">
    <div class="max-w-3xl mx-auto px-6">
      <h2 class="text-3xl font-bold mb-10">The journey</h2>
      <div class="space-y-6">
        {career.map((c: { period: string; title: string; description: string }) => (
          <div class="flex gap-6">
            <div class="text-teal-400 font-mono text-sm pt-1 w-24 shrink-0">{c.period}</div>
            <div>
              <h3 class="font-semibold text-gray-100">{c.title}</h3>
              <p class="text-gray-400">{c.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Recognition -->
  <section id="recognition" class="py-20 border-t border-gray-800">
    <div class="max-w-3xl mx-auto px-6">
      <h2 class="text-3xl font-bold mb-8">Recognition</h2>
      <ul class="space-y-3 text-lg text-gray-300">
        {recognition.map((item: string) => (
          <li>{item}</li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Connect -->
  <section id="connect" class="py-20 border-t border-gray-800">
    <div class="max-w-3xl mx-auto px-6">
      <h2 class="text-3xl font-bold mb-6">{connect.heading}</h2>
      <p class="text-lg text-gray-300 mb-8 leading-relaxed">{connect.text}</p>
      <a href={`mailto:${connect.email}`} class="inline-block bg-teal-500 hover:bg-teal-400 text-gray-950 font-semibold px-6 py-3 rounded-lg transition-colors mb-8">
        {connect.email}
      </a>
      <div class="flex flex-wrap gap-6 text-lg">
        {connect.links.map((link: { label: string; url: string }) => (
          <a href={link.url} target="_blank" rel="noopener" class="text-teal-400 hover:text-teal-300 transition-colors">{link.label}</a>
        ))}
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="py-10 border-t border-gray-800">
    <div class="max-w-3xl mx-auto px-6 text-gray-600 text-sm">
      &copy; {new Date().getFullYear()} Brian Borg. Boulder, CO.
    </div>
  </footer>
</Layout>
